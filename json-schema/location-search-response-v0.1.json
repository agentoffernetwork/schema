{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agentoffernetwork.org/schema/location-search-response/v0.1",
  "title": "AON Location Search API response v0.1",
  "type": "object",
  "required": ["code", "message", "data", "extra"],
  "additionalProperties": false,
  "properties": {
    "code": {
      "type": "string",
      "const": "SUCCESS"
    },
    "message": {
      "type": "string"
    },
    "data": {
      "type": "object",
      "required": ["registry_version", "source_file_date", "locations"],
      "additionalProperties": false,
      "properties": {
        "registry_version": {
          "type": "string",
          "const": "v1"
        },
        "source_file_date": {
          "type": "string",
          "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
        },
        "locations": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/locationSearchResult"
          }
        }
      }
    },
    "extra": {
      "type": "object"
    }
  },
  "$defs": {
    "locationPathItem": {
      "type": "object",
      "required": ["location_id", "name", "level"],
      "additionalProperties": false,
      "properties": {
        "location_id": {
          "type": "string",
          "pattern": "^[0-9]+$"
        },
        "name": {
          "type": "string",
          "minLength": 1
        },
        "level": {
          "type": "string",
          "enum": ["COUNTRY", "REGION", "CITY"]
        }
      }
    },
    "locationExternalCodes": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "iso_3166_2": {
          "type": "string",
          "pattern": "^[A-Z]{2}-[A-Z0-9]{1,3}$"
        },
        "cldr_subdivision": {
          "type": "string",
          "pattern": "^[A-Z]{2}[A-Z0-9]{1,3}$"
        },
        "provider_short": {
          "type": "string",
          "pattern": "^[A-Z0-9]{1,3}$"
        }
      },
      "anyOf": [
        { "required": ["iso_3166_2"] },
        { "required": ["cldr_subdivision"] },
        { "required": ["provider_short"] }
      ]
    },
    "locationSearchResult": {
      "type": "object",
      "required": [
        "location_id",
        "name",
        "canonical_name",
        "country_code",
        "level",
        "target_type",
        "parent_location_id",
        "path"
      ],
      "additionalProperties": false,
      "properties": {
        "location_id": {
          "type": "string",
          "pattern": "^[0-9]+$"
        },
        "name": {
          "type": "string",
          "minLength": 1
        },
        "canonical_name": {
          "type": "string",
          "minLength": 1
        },
        "country_code": {
          "type": "string",
          "pattern": "^[A-Z]{2}$"
        },
        "level": {
          "type": "string",
          "enum": ["COUNTRY", "REGION", "CITY"]
        },
        "target_type": {
          "type": "string",
          "minLength": 1
        },
        "parent_location_id": {
          "type": ["string", "null"],
          "pattern": "^[0-9]+$"
        },
        "path": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/locationPathItem"
          }
        },
        "external_codes": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "iso_3166_2": {
              "type": "string",
              "pattern": "^[A-Z]{2}-[A-Z0-9]{1,3}$"
            },
            "cldr_subdivision": {
              "type": "string",
              "pattern": "^[A-Z]{2}[A-Z0-9]{1,3}$"
            },
            "provider_short": {
              "type": "string",
              "pattern": "^[A-Z0-9]{1,3}$"
            }
          },
          "anyOf": [
            { "required": ["iso_3166_2"] },
            { "required": ["cldr_subdivision"] },
            { "required": ["provider_short"] }
          ]
        }
      }
    },
    "locationResolveResponse": {
      "type": "object",
      "required": ["code", "message", "data", "extra"],
      "additionalProperties": false,
      "properties": {
        "code": {
          "type": "string",
          "const": "SUCCESS"
        },
        "message": {
          "type": "string"
        },
        "data": {
          "type": "object",
          "required": [
            "registry_version",
            "source_file_date",
            "location",
            "location_ids",
            "candidates",
            "input"
          ],
          "additionalProperties": false,
          "properties": {
            "registry_version": {
              "type": "string",
              "const": "v1"
            },
            "source_file_date": {
              "type": "string",
              "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
            },
            "location": {
              "anyOf": [
                { "$ref": "#/$defs/locationSearchResult" },
                { "type": "null" }
              ]
            },
            "location_ids": {
              "type": "array",
              "items": {
                "type": "string",
                "pattern": "^[0-9]+$"
              }
            },
            "candidates": {
              "type": "array",
              "items": {
                "$ref": "#/$defs/locationSearchResult"
              }
            },
            "input": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "country": {
                  "type": "string",
                  "pattern": "^[A-Z]{2}$"
                },
                "subdivision_code": {
                  "type": "string",
                  "minLength": 1
                },
                "subdivision_code_type": {
                  "type": "string",
                  "enum": ["AUTO", "ISO_3166_2", "CLDR", "PROVIDER_SHORT"]
                },
                "city": {
                  "type": "string",
                  "minLength": 1
                }
              }
            }
          }
        },
        "extra": {
          "type": "object"
        }
      }
    }
  }
}
