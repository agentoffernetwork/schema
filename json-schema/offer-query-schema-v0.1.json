{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agentoffernetwork.org/schema/offer-query/v0.1",
  "title": "AgentOffer Query Request Schema v0.1",
  "description": "Structured query request for discovering offers via POST /v1/offers/query. Uses RFC 2119 requirement levels (REQUIRED/RECOMMENDED/OPTIONAL).",
  "type": "object",
  "required": [
    "context",
    "intent"
  ],
  "properties": {
    "request_id": {
      "type": "string",
      "description": "Unique request identifier. UUIDv7 recommended.",
      "format": "uuid"
    },
    "timestamp": {
      "type": "string",
      "format": "date-time",
      "description": "RFC 3339 timestamp of the request."
    },
    "test_mode": {
      "type": "boolean",
      "description": "When true, request is treated as test. Defaults to false.",
      "default": false
    },
    "context": {
      "type": "object",
      "description": "Contextual information about the requesting platform, session, and user.",
      "required": [
        "user_profile"
      ],
      "properties": {
        "platform": {
          "type": "object",
          "description": "Information about the requesting platform or agent.",
          "properties": {
            "name": {
              "type": "string",
              "description": "Platform or agent name."
            },
            "version": {
              "type": "string",
              "description": "Platform or model version."
            },
            "channel": {
              "type": "string",
              "description": "Integration channel."
            }
          },
          "additionalProperties": false
        },
        "session_id": {
          "type": "string",
          "description": "Session identifier for grouping related queries."
        },
        "user_profile": {
          "type": "object",
          "description": "User profile information for intent matching and targeting.",
          "required": [],
          "properties": {
            "user_pseudo_id": {
              "type": "string",
              "description": "Pseudonymous viewer identifier."
            },
            "language": {
              "type": "string",
              "description": "User language preference. ISO 639-1 code."
            },
            "country": {
              "type": "string",
              "pattern": "^[A-Za-z]{2}$",
              "description": "User country for geo targeting. ISO 3166-1 alpha-2 code."
            },
            "interests": {
              "type": "array",
              "items": { "type": "string" },
              "description": "User interest tags. May be empty array."
            },
            "device_info": {
              "type": "object",
              "description": "Device information for targeting.",
              "properties": {
                "device_type": {
                  "type": "string",
                  "description": "Device type."
                },
                "os": {
                  "type": "string",
                  "description": "Operating system."
                },
                "os_version": {
                  "type": "string",
                  "description": "OS version string."
                }
              },
              "additionalProperties": false
            }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },
    "intent": {
      "type": "object",
      "description": "The user's intent expressed as multimodal content.",
      "required": ["content"],
      "properties": {
        "content": {
          "type": "array",
          "description": "Array of content items. At least one item required.",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": ["type"],
            "properties": {
              "type": {
                "type": "string",
                "enum": ["input_text", "input_image"],
                "description": "Content type."
              },
              "text": {
                "type": "string",
                "description": "Text content (when type=input_text)."
              },
              "image_url": {
                "type": "string",
                "format": "uri",
                "description": "Image URL (when type=input_image)."
              }
            },
            "additionalProperties": false
          }
        }
      },
      "additionalProperties": false
    },
    "constraints": {
      "type": "object",
      "description": "Deterministic eligibility constraints that narrow the result set before semantic ranking. constraints is a hard constraint surface, intent is a soft signal for semantic relevance. The first public constraints surface only exposes category_types.",
      "properties": {
        "category_types": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "software_saas",
              "travel_hospitality",
              "education",
              "financial_service",
              "electronics",
              "entertainment",
              "health_beauty",
              "fashion",
              "food_grocery",
              "home_garden",
              "automotive"
            ]
          },
          "description": "Constrain by category type. Values reference offer_info.category.type enum. OR logic: matches any specified type."
        }
      },
      "additionalProperties": false
    },
    "pagination": {
      "type": "object",
      "description": "Pagination control.",
      "properties": {
        "limit": {
          "type": "integer",
          "minimum": 1,
          "maximum": 100,
          "default": 20,
          "description": "Number of offers to return."
        },
        "offset": {
          "type": "integer",
          "minimum": 0,
          "default": 0,
          "description": "Number of offers to skip."
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
