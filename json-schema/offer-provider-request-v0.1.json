{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agentoffernetwork.org/schema/offer-provider-request/v0.1",
  "title": "AgentOffer OfferProvider Request Schema v0.1",
  "description": "Request body that AON sends to a Partner's OfferProvider endpoint (POST {base_url}/v1/offers/query). Reuses the canonical OfferQueryRequest shape defined by offer-query-schema-v0.1.json. Uses RFC 2119 requirement levels (REQUIRED/RECOMMENDED/OPTIONAL).",
  "type": "object",
  "required": [
    "context",
    "intent"
  ],
  "properties": {
    "request_id": {
      "type": "string",
      "description": "Unique request identifier. UUIDv7 recommended. Generated by AON; Partner MAY echo it in logs.",
      "format": "uuid"
    },
    "timestamp": {
      "type": "string",
      "format": "date-time",
      "description": "RFC 3339 timestamp of the request. Set by AON at dispatch time."
    },
    "test_mode": {
      "type": "boolean",
      "description": "When true, the request is a test and Partner SHOULD NOT generate real tracking or billing events. The authoritative test-mode signal is the X-AON-Test HTTP header; this body field is retained for protocol parity with OfferQueryRequest.",
      "default": false
    },
    "context": {
      "type": "object",
      "description": "Contextual information about the requesting platform, session, and user.",
      "required": [
        "user_profile"
      ],
      "properties": {
        "platform": {
          "type": "object",
          "description": "Information about the requesting platform or agent.",
          "properties": {
            "name": { "type": "string" },
            "version": { "type": "string" },
            "channel": { "type": "string" }
          },
          "additionalProperties": false
        },
        "session_id": { "type": "string" },
        "conversation_id": {
          "type": ["string", "number"],
          "description": "Conversation or thread identifier within the session."
        },
        "user_profile": {
          "type": "object",
          "description": "User profile information for intent matching and targeting.",
          "properties": {
            "user_pseudo_id": { "type": "string" },
            "viewer_id": { "type": "string" },
            "language": { "type": "string" },
            "interests": {
              "type": "array",
              "items": { "type": "string" }
            },
            "device_info": {
              "type": "object",
              "properties": {
                "device_type": { "type": "string" },
                "os": { "type": "string" },
                "os_version": { "type": "string" }
              },
              "additionalProperties": false
            }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },
    "intent": {
      "type": "object",
      "description": "The user's intent expressed as multimodal content.",
      "required": ["content"],
      "properties": {
        "content": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": ["type"],
            "properties": {
              "type": {
                "type": "string",
                "enum": ["input_text", "input_image"]
              },
              "text": { "type": "string" },
              "image_url": {
                "type": "string",
                "format": "uri"
              }
            },
            "additionalProperties": false
          }
        }
      },
      "additionalProperties": false
    },
    "filter": {
      "type": "object",
      "description": "Structured filter constraints applied as hard constraints before semantic ranking.",
      "properties": {
        "category_types": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "software_saas",
              "travel_hospitality",
              "education",
              "financial_service",
              "electronics",
              "entertainment",
              "health_beauty",
              "fashion",
              "food_grocery",
              "home_garden",
              "automotive"
            ]
          }
        },
        "bid_models": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": ["cpa", "cps", "cpl", "cpi", "hybrid"]
          }
        },
        "status": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": ["active", "paused", "pending", "rejected", "expired"]
          }
        },
        "availability": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": ["available", "limited", "out_of_stock", "coming_soon"]
          }
        },
        "min_bid_amount": { "type": "string" },
        "max_price_amount": { "type": "string" },
        "currency": { "type": "string" },
        "brand": { "type": "string" },
        "country": { "type": "string" },
        "tags": {
          "type": "array",
          "items": { "type": "string" }
        }
      },
      "additionalProperties": false
    },
    "pagination": {
      "type": "object",
      "properties": {
        "limit": {
          "type": "integer",
          "minimum": 1,
          "maximum": 100,
          "default": 20
        },
        "offset": {
          "type": "integer",
          "minimum": 0,
          "default": 0
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
