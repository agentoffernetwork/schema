{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agentoffernetwork.org/schema/offer/v0.1",
  "title": "AgentOffer Offer Schema v0.1",
  "description": "Standardized protocol schema for AgentOffer objects. Uses RFC 2119 requirement levels: REQUIRED fields MUST be present with valid values, RECOMMENDED fields SHOULD be present and follow the standard structure but values MAY be empty, OPTIONAL fields MAY be omitted entirely.",
  "type": "object",
  "required": [
    "uuid",
    "version",
    "offer_info",
    "entity",
    "action",
    "material"
  ],
  "properties": {
    "uuid": {
      "type": "string",
      "description": "Globally unique identifier for the offer. UUIDv7 format is recommended.",
      "format": "uuid"
    },
    "version": {
      "type": "string",
      "description": "Offer document version indicating which schema revision the instance conforms to.",
      "default": "1.0"
    },
    "offer_info": {
      "type": "object",
      "description": "Core descriptive, categorical, and commercial information for the offer.",
      "required": [
        "title",
        "offer_type",
        "category",
        "description"
      ],
      "properties": {
        "title": {
          "type": "string",
          "description": "Display-ready offer title.",
          "minLength": 1,
          "maxLength": 200
        },
        "offer_type": {
          "type": "string",
          "enum": [
            "physical_product",
            "content",
            "online_service",
            "offline_service"
          ],
          "description": "Offer delivery form classification (how the offer is fulfilled)."
        },
        "category": {
          "type": "object",
          "description": "Industry vertical classification, vertical-specific attributes, and commercial context.",
          "required": [
            "type",
            "attributes",
            "commercial"
          ],
          "properties": {
            "type": {
              "type": "string",
              "enum": [
                "software_saas",
                "travel_hospitality",
                "education",
                "financial_service",
                "electronics",
                "entertainment",
                "health_beauty",
                "fashion",
                "food_grocery",
                "home_garden",
                "automotive"
              ],
              "description": "Industry vertical identifier. All types use attributes.sub_type for finer classification."
            },
            "attributes": {
              "type": "object",
              "description": "Vertical-specific attributes. Structure varies by category.type and attributes.sub_type. The sub_type field is REQUIRED within attributes for all category types.",
              "required": ["sub_type"],
              "properties": {
                "sub_type": {
                  "type": "string",
                  "description": "Industry sub-category discriminator. Valid values depend on the parent category.type."
                }
              },
              "allOf": [
                {
                  "if": {
                    "properties": {
                      "sub_type": {
                        "enum": [
                          "skincare",
                          "supplement",
                          "fitness",
                          "cosmetics",
                          "wellness",
                          "medical_device"
                        ]
                      }
                    }
                  },
                  "then": {
                    "properties": {
                      "ingredients_highlight": {
                        "type": "array",
                        "items": { "type": "string" },
                        "description": "Key ingredients or active compounds highlighted for the product."
                      },
                      "skin_type": {
                        "type": "string",
                        "description": "Target skin type such as oily, dry, combination, sensitive, normal."
                      },
                      "organic": {
                        "type": "boolean",
                        "description": "Whether the product holds an organic certification."
                      }
                    }
                  }
                },
                {
                  "if": {
                    "properties": {
                      "sub_type": {
                        "enum": [
                          "clothing",
                          "shoes",
                          "accessories",
                          "jewelry",
                          "luxury",
                          "sportswear"
                        ]
                      }
                    }
                  },
                  "then": {
                    "properties": {
                      "gender": {
                        "type": "string",
                        "description": "Target gender: unisex, male, female."
                      },
                      "size_range": {
                        "type": "string",
                        "description": "Available size range description (e.g., XS-XXL, 6-12)."
                      },
                      "material": {
                        "type": "string",
                        "description": "Primary material or fabric."
                      }
                    }
                  }
                },
                {
                  "if": {
                    "properties": {
                      "sub_type": {
                        "enum": [
                          "meal_kit",
                          "grocery_delivery",
                          "specialty_food",
                          "beverage",
                          "organic",
                          "snack"
                        ]
                      }
                    }
                  },
                  "then": {
                    "properties": {
                      "dietary_info": {
                        "type": "array",
                        "items": { "type": "string" },
                        "description": "Dietary labels such as vegan, gluten_free, keto, halal, kosher, organic."
                      },
                      "shelf_life_days": {
                        "type": "integer",
                        "description": "Shelf life in days."
                      },
                      "serving_size": {
                        "type": "string",
                        "description": "Serving size description."
                      }
                    }
                  }
                },
                {
                  "if": {
                    "properties": {
                      "sub_type": {
                        "enum": [
                          "furniture",
                          "appliance",
                          "decor",
                          "smart_home",
                          "garden",
                          "cleaning"
                        ]
                      }
                    }
                  },
                  "then": {
                    "properties": {
                      "dimensions": {
                        "type": "string",
                        "description": "Product dimensions description (e.g., 120x60x75 cm)."
                      },
                      "assembly_required": {
                        "type": "boolean",
                        "description": "Whether assembly is required."
                      },
                      "energy_rating": {
                        "type": "string",
                        "description": "Energy efficiency rating (e.g., A+, Energy Star)."
                      }
                    }
                  }
                },
                {
                  "if": {
                    "properties": {
                      "sub_type": {
                        "enum": [
                          "car_purchase",
                          "car_lease",
                          "insurance",
                          "parts",
                          "ev_charging",
                          "ride_service"
                        ]
                      }
                    }
                  },
                  "then": {
                    "properties": {
                      "vehicle_type": {
                        "type": "string",
                        "description": "Vehicle classification such as sedan, suv, truck, ev, motorcycle."
                      },
                      "fuel_type": {
                        "type": "string",
                        "description": "Fuel or power type: gasoline, diesel, electric, hybrid."
                      },
                      "warranty_years": {
                        "type": "integer",
                        "description": "Warranty duration in years."
                      }
                    }
                  }
                }
              ],
              "additionalProperties": true
            },
            "commercial": {
              "type": "object",
              "description": "Pricing, availability, and inventory information.",
              "properties": {
                "price": {
                  "type": "object",
                  "properties": {
                    "amount": {
                      "type": "string",
                      "description": "Decimal string representing the consumer-facing price amount."
                    },
                    "currency": {
                      "type": "string",
                      "description": "ISO 4217 currency code."
                    }
                  },
                  "additionalProperties": false
                },
                "availability": {
                  "type": "string",
                  "enum": [
                    "available",
                    "limited",
                    "sold_out",
                    "pre_order"
                  ],
                  "description": "Inventory availability status."
                },
                "stock": {
                  "type": "integer",
                  "minimum": 0,
                  "description": "Available inventory count. Omit for unlimited inventory."
                }
              },
              "additionalProperties": false
            }
          },
          "additionalProperties": false
        },
        "description": {
          "type": "string",
          "description": "Core semantic description for agent understanding and end-user display.",
          "minLength": 1,
          "maxLength": 5000
        },
        "source_offer_id": {
          "type": "string",
          "description": "Upstream source-side offer or inventory identifier."
        },
        "start_at": {
          "type": "string",
          "format": "date-time",
          "description": "RFC 3339 timestamp for when the offer becomes active."
        },
        "expire_at": {
          "type": "string",
          "format": "date-time",
          "description": "RFC 3339 timestamp for when the offer expires."
        },
        "status": {
          "type": "string",
          "enum": [
            "active",
            "paused",
            "pending",
            "rejected",
            "expired"
          ],
          "description": "Lifecycle status of the offer.",
          "default": "pending"
        },
        "audit_status": {
          "type": "string",
          "enum": [
            "waiting",
            "pass",
            "reject"
          ],
          "description": "Compliance audit status.",
          "default": "waiting"
        },
        "priority": {
          "type": "integer",
          "minimum": 0,
          "maximum": 100,
          "description": "Exposure priority. Higher values take precedence.",
          "default": 10
        }
      },
      "additionalProperties": false
    },
    "material": {
      "type": "array",
      "description": "Creative assets associated with the offer.",
      "items": {
        "type": "object",
        "properties": {
          "image_url": {
            "type": "string",
            "format": "uri",
            "description": "URL to the creative asset."
          },
          "tag": {
            "type": "string",
            "description": "Asset purpose tag such as logo, banner, hero, thumbnail."
          },
          "format": {
            "type": "string",
            "enum": [
              "image",
              "video",
              "html5"
            ],
            "description": "Asset format."
          },
          "size": {
            "type": "string",
            "description": "Dimension specification such as 300x250, 728x90."
          }
        },
        "additionalProperties": false
      }
    },
    "conversion_rule": {
      "type": "object",
      "description": "Rules for valid conversion events, attribution logic, and tracking windows. RECOMMENDED: SHOULD be present to establish clear attribution expectations.",
      "properties": {
        "click_window_hours": {
          "type": "integer",
          "minimum": 0,
          "description": "Click attribution window in hours. Conversions within this window after a click are eligible for attribution.",
          "default": 720
        },
        "view_window_hours": {
          "type": "integer",
          "minimum": 0,
          "description": "View-through attribution window in hours. Default 0 (view-through attribution not supported).",
          "default": 0
        },
        "attribution_model": {
          "type": "string",
          "enum": [
            "last_click",
            "first_click"
          ],
          "description": "Attribution method. last_click: credit goes to the last click before conversion. first_click: credit goes to the first click. linear is reserved for future use.",
          "default": "last_click"
        },
        "accepted_types": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "sale",
              "lead",
              "install",
              "subscription",
              "trial",
              "custom"
            ]
          },
          "description": "Accepted conversion types for this offer. Values reference the conversion_type enumeration."
        },
        "dedup_strategy": {
          "type": "string",
          "enum": [
            "first",
            "all",
            "highest"
          ],
          "description": "Deduplication strategy for multiple conversions from the same user. first: only the first conversion counts. all: every conversion counts. highest: only the highest-value conversion counts.",
          "default": "first"
        },
        "minimum_amount": {
          "type": "string",
          "description": "Minimum conversion amount, decimal string. Conversions below this threshold do not qualify for commission."
        }
      },
      "additionalProperties": false
    },
    "frequency_capping": {
      "type": "object",
      "description": "Exposure frequency limits.",
      "properties": {
        "per_user_day": {
          "type": "integer",
          "minimum": 0,
          "description": "Maximum impressions per user per day."
        },
        "per_user_total": {
          "type": "integer",
          "minimum": 0,
          "description": "Maximum lifetime impressions per user."
        }
      },
      "additionalProperties": false
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "Custom tags for filtering and semantic matching."
    },
    "entity": {
      "type": "object",
      "description": "Business entity associated with the offer.",
      "required": [
        "id",
        "name"
      ],
      "properties": {
        "id": {
          "type": "string",
          "description": "Stable entity identifier."
        },
        "name": {
          "type": "string",
          "description": "Display name of the entity."
        },
        "type": {
          "type": "string",
          "description": "Entity classification such as merchant, brand, creator, seller, service_provider."
        },
        "description": {
          "type": "string",
          "description": "Short description of the entity."
        },
        "website": {
          "type": "string",
          "format": "uri",
          "description": "Official website of the entity."
        }
      },
      "additionalProperties": false
    },
    "action": {
      "type": "object",
      "description": "Primary executable action exposed by the offer.",
      "required": [
        "type",
        "payload"
      ],
      "properties": {
        "type": {
          "type": "string",
          "enum": [
            "web_redirect",
            "app_deep_link",
            "api_trigger"
          ],
          "description": "Executable action type."
        },
        "name": {
          "type": "string",
          "description": "Short user-facing action name (CTA text).",
          "maxLength": 80
        },
        "description": {
          "type": "string",
          "description": "Explanation of the action intent or destination.",
          "maxLength": 300
        },
        "payload": {
          "type": "object",
          "required": [
            "target"
          ],
          "properties": {
            "target": {
              "type": "string",
              "format": "uri",
              "description": "Destination URL, deep link, or API endpoint."
            },
            "requires_auth": {
              "type": "boolean",
              "description": "Whether the user must authenticate to complete the action."
            },
            "platform": {
              "type": "string",
              "enum": [
                "web",
                "ios",
                "android",
                "desktop"
              ],
              "description": "Target platform for the action flow."
            }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },
    "targeting": {
      "type": "array",
      "description": "Targeting constraints for offer surfacing.",
      "items": {
        "type": "object",
        "properties": {
          "geo": {
            "type": "object",
            "properties": {
              "include": {
                "type": "array",
                "items": {
                  "type": "string"
                },
                "description": "Included geographic regions."
              },
              "exclude": {
                "type": "array",
                "items": {
                  "type": "string"
                },
                "description": "Excluded geographic regions."
              }
            },
            "additionalProperties": false
          },
          "language": {
            "type": "string",
            "description": "Target language, ISO 639-1 code."
          },
          "device_type": {
            "type": "array",
            "items": {
              "type": "string",
              "enum": [
                "mobile",
                "desktop",
                "tablet",
                "smart_tv"
              ]
            },
            "description": "Target device types."
          }
        },
        "additionalProperties": false
      }
    },
    "source": {
      "type": "object",
      "description": "Offer origin and tracking configuration for affiliate workflows.",
      "properties": {
        "postback_url_template": {
          "type": "string",
          "description": "Agent-side conversion callback URL template. Supports variable substitution (e.g., {tracking_id}, {offer_id}, {conversion_type}, {amount}, {commission_amount}, {currency}, {sub_id_1}...{sub_id_5}, {timestamp})."
        },
        "tracking_url_template": {
          "type": "string",
          "description": "Tracking link generation template. Used to construct click-tracking URLs with embedded parameters."
        }
      },
      "additionalProperties": false
    },
    "commission": {
      "type": "object",
      "description": "Affiliate commission and payout information. RECOMMENDED: SHOULD be present when the offer participates in affiliate or performance-based compensation.",
      "required": [
        "model",
        "currency"
      ],
      "properties": {
        "model": {
          "type": "string",
          "enum": [
            "cpa",
            "cps",
            "cpl",
            "cpi",
            "hybrid"
          ],
          "description": "Commission model: cpa (cost per action), cps (cost per sale, percentage-based), cpl (cost per lead), cpi (cost per install), hybrid (base amount plus percentage)."
        },
        "amount": {
          "type": "string",
          "description": "Fixed commission amount, decimal string. REQUIRED for cpa/cpl/cpi/hybrid, OPTIONAL for cps."
        },
        "currency": {
          "type": "string",
          "description": "ISO 4217 currency code for the commission amount."
        },
        "rate": {
          "type": "string",
          "description": "Commission rate as a decimal string (e.g., 0.15 = 15%). REQUIRED for cps/hybrid, OPTIONAL for other models."
        },
        "tier": {
          "type": "array",
          "description": "Tiered commission rules. When present, tier rules take precedence over top-level amount/rate.",
          "items": {
            "type": "object",
            "required": [
              "threshold",
              "threshold_type"
            ],
            "properties": {
              "threshold": {
                "type": "string",
                "description": "Threshold value that triggers this tier, decimal string."
              },
              "threshold_type": {
                "type": "string",
                "enum": [
                  "revenue",
                  "count"
                ],
                "description": "Threshold measurement type: revenue (cumulative amount) or count (cumulative conversions)."
              },
              "amount": {
                "type": "string",
                "description": "Fixed commission for this tier. Used when parent model is cpa, cpl, cpi, or hybrid."
              },
              "rate": {
                "type": "string",
                "description": "Commission rate for this tier. Used when parent model is cps or hybrid."
              }
            },
            "additionalProperties": false
          }
        },
        "cap": {
          "type": "string",
          "description": "Maximum commission per single conversion, decimal string."
        },
        "cap_currency": {
          "type": "string",
          "description": "Currency for the commission cap. When omitted, defaults to commission.currency."
        },
        "payout_delay_days": {
          "type": "integer",
          "minimum": 0,
          "description": "Settlement delay in days (lock-up period).",
          "default": 0
        },
        "validation_window_days": {
          "type": "integer",
          "minimum": 0,
          "description": "Conversion validation window in days (advertiser confirmation period)."
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "model": { "enum": ["cpa", "cpl", "cpi"] }
            },
            "required": ["model"]
          },
          "then": {
            "required": ["amount"]
          }
        },
        {
          "if": {
            "properties": {
              "model": { "const": "cps" }
            },
            "required": ["model"]
          },
          "then": {
            "required": ["rate"]
          }
        },
        {
          "if": {
            "properties": {
              "model": { "const": "hybrid" }
            },
            "required": ["model"]
          },
          "then": {
            "required": ["amount", "rate"]
          }
        }
      ],
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
