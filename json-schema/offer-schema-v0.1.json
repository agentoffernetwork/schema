{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agentoffernetwork.org/schema/offer/v0.1",
  "title": "AgentOffer Offer Schema v0.1",
  "description": "Standardized protocol schema for AgentOffer objects. Uses RFC 2119 requirement levels: REQUIRED fields MUST be present with valid values, RECOMMENDED fields SHOULD be present and follow the standard structure but values MAY be empty, OPTIONAL fields MAY be omitted entirely.",
  "type": "object",
  "required": [
    "uuid",
    "version",
    "offer_info",
    "entity",
    "action",
    "commission"
  ],
  "properties": {
    "uuid": {
      "type": "string",
      "description": "Globally unique identifier for the offer. UUIDv7 format is recommended.",
      "format": "uuid"
    },
    "version": {
      "type": "string",
      "description": "Offer document version indicating which schema revision the instance conforms to.",
      "default": "1.0"
    },
    "offer_info": {
      "type": "object",
      "description": "Core descriptive, categorical, and commercial information for the offer.",
      "required": [
        "title",
        "offer_type",
        "category",
        "description"
      ],
      "properties": {
        "title": {
          "type": "string",
          "description": "Display-ready offer title.",
          "minLength": 1,
          "maxLength": 200
        },
        "offer_type": {
          "type": "string",
          "enum": [
            "physical_product",
            "digital_goods",
            "content",
            "online_service",
            "offline_service"
          ],
          "description": "Offer fulfillment form — how the offer is delivered to the end user. Determines Agent-side UX behavior: physical_product (shipping/returns), content (instant access), online_service (signup/subscription), offline_service (location/booking). Orthogonal to category.type (industry classification)."
        },
        "category": {
          "type": "object",
          "description": "Industry vertical classification and vertical-specific attributes.",
          "required": [
            "type",
            "attributes"
          ],
          "properties": {
            "type": {
              "type": "string",
              "enum": [
                "software_saas",
                "travel_hospitality",
                "education",
                "financial_service",
                "electronics",
                "entertainment"
              ],
              "description": "Industry vertical identifier. All types use attributes.sub_type for finer classification."
            },
            "attributes": {
              "type": "object",
              "description": "Vertical-specific attributes. Structure varies by category.type and attributes.sub_type. The sub_type field is REQUIRED within attributes for all category types.",
              "required": ["sub_type"],
              "properties": {
                "sub_type": {
                  "type": "string",
                  "description": "Industry sub-category discriminator. Valid values depend on the parent category.type."
                }
              },
              "additionalProperties": true
            }
          },
          "allOf": [
            {
              "if": {
                "properties": { "type": { "const": "software_saas" } },
                "required": ["type"]
              },
              "then": {
                "properties": {
                  "attributes": {
                    "required": ["sub_type", "plan_type", "platform"],
                    "properties": {
                      "sub_type": {
                        "type": "string",
                        "enum": [
                          "project_management",
                          "design",
                          "development_tools",
                          "crm",
                          "analytics",
                          "communication",
                          "security",
                          "ai_tools"
                        ]
                      },
                      "plan_type": {
                        "type": "string",
                        "enum": ["free_trial", "freemium", "paid", "open_source"],
                        "description": "Subscription or pricing model."
                      },
                      "platform": {
                        "type": "array",
                        "items": {
                          "type": "string",
                          "enum": ["web", "desktop", "mobile", "api"]
                        },
                        "description": "Supported platforms."
                      },
                      "trial_days": {
                        "type": "integer",
                        "minimum": 0,
                        "description": "Free trial duration in days."
                      },
                      "features": {
                        "type": "array",
                        "items": { "type": "string" },
                        "description": "Key feature highlights."
                      },
                      "integrations": {
                        "type": "array",
                        "items": { "type": "string" },
                        "description": "Third-party integrations supported."
                      },
                      "seats_included": {
                        "type": "integer",
                        "minimum": 1,
                        "description": "Number of seats included in the plan."
                      },
                      "deployment": {
                        "type": "string",
                        "enum": ["cloud", "on_premise", "hybrid"],
                        "description": "Deployment model."
                      }
                    }
                  }
                }
              }
            },
            {
              "if": {
                "properties": { "type": { "const": "travel_hospitality" } },
                "required": ["type"]
              },
              "then": {
                "properties": {
                  "attributes": {
                    "required": ["sub_type", "destination"],
                    "properties": {
                      "sub_type": {
                        "type": "string",
                        "enum": [
                          "hotel",
                          "flight",
                          "car_rental",
                          "vacation_package",
                          "restaurant",
                          "attraction"
                        ]
                      },
                      "destination": {
                        "type": "object",
                        "description": "Destination location.",
                        "required": ["city", "country"],
                        "properties": {
                          "city": {
                            "type": "string",
                            "description": "Destination city."
                          },
                          "country": {
                            "type": "string",
                            "description": "Destination country."
                          }
                        },
                        "additionalProperties": false
                      },
                      "cancellation_policy": {
                        "type": "string",
                        "description": "Cancellation policy summary."
                      }
                    }
                  }
                }
              }
            },
            {
              "if": {
                "properties": { "type": { "const": "education" } },
                "required": ["type"]
              },
              "then": {
                "properties": {
                  "attributes": {
                    "required": ["sub_type", "subject", "level"],
                    "properties": {
                      "sub_type": {
                        "type": "string",
                        "enum": [
                          "online_course",
                          "certification",
                          "bootcamp",
                          "language_learning",
                          "tutoring",
                          "academic_program"
                        ]
                      },
                      "subject": {
                        "type": "string",
                        "description": "Subject or topic area."
                      },
                      "level": {
                        "type": "string",
                        "enum": ["beginner", "intermediate", "advanced", "professional"],
                        "description": "Target learner level."
                      },
                      "language": {
                        "type": "string",
                        "description": "Language of instruction."
                      },
                      "certification": {
                        "type": "boolean",
                        "description": "Whether a certificate is awarded."
                      }
                    }
                  }
                }
              }
            },
            {
              "if": {
                "properties": { "type": { "const": "financial_service" } },
                "required": ["type"]
              },
              "then": {
                "properties": {
                  "attributes": {
                    "required": ["sub_type", "provider_license"],
                    "properties": {
                      "sub_type": {
                        "type": "string",
                        "enum": [
                          "credit_card",
                          "insurance",
                          "loan",
                          "investment",
                          "banking",
                          "payment"
                        ]
                      },
                      "provider_license": {
                        "type": "string",
                        "description": "Regulatory license or registration identifier."
                      }
                    }
                  }
                }
              }
            },
            {
              "if": {
                "properties": { "type": { "const": "electronics" } },
                "required": ["type"]
              },
              "then": {
                "properties": {
                  "attributes": {
                    "required": ["sub_type", "brand", "model", "condition"],
                    "properties": {
                      "sub_type": {
                        "type": "string",
                        "enum": [
                          "smartphone",
                          "laptop",
                          "audio",
                          "wearable",
                          "gaming_hardware",
                          "smart_home",
                          "camera"
                        ]
                      },
                      "brand": {
                        "type": "string",
                        "description": "Manufacturer brand."
                      },
                      "model": {
                        "type": "string",
                        "description": "Product model name or number."
                      },
                      "condition": {
                        "type": "string",
                        "enum": ["new", "refurbished", "used"],
                        "description": "Item condition."
                      },
                      "warranty_months": {
                        "type": "integer",
                        "minimum": 0,
                        "description": "Warranty duration in months."
                      },
                      "color": {
                        "type": "string",
                        "description": "Color or finish."
                      }
                    }
                  }
                }
              }
            },
            {
              "if": {
                "properties": { "type": { "const": "entertainment" } },
                "required": ["type"]
              },
              "then": {
                "properties": {
                  "attributes": {
                    "required": ["sub_type"],
                    "properties": {
                      "sub_type": {
                        "type": "string",
                        "enum": [
                          "game",
                          "streaming_video",
                          "ai_companion",
                          "social_audio",
                          "sports_betting",
                          "music_audio",
                          "live_streaming"
                        ]
                      },
                      "supported_devices": {
                        "type": "array",
                        "items": { "type": "string" },
                        "description": "Supported devices or platforms."
                      },
                      "age_rating": {
                        "type": "string",
                        "description": "Age or content rating (e.g., ESRB T, PEGI 12, MPAA PG-13)."
                      },
                      "languages": {
                        "type": "array",
                        "items": { "type": "string" },
                        "description": "Supported languages."
                      }
                    }
                  }
                }
              }
            }
          ],
          "additionalProperties": false
        },
        "description": {
          "type": "string",
          "description": "Core semantic description for agent understanding and end-user display.",
          "minLength": 1,
          "maxLength": 5000
        },
        "recommendation_reason": {
          "type": "string",
          "description": "Partner-provided recommendation reason for AON ranking engine. Contains conversion advantages, target audience hints, and promotional context. Not shown to end users.",
          "maxLength": 1000
        },
        "commercial": {
          "type": "object",
          "description": "Pricing information.",
          "properties": {
            "price": {
              "type": "object",
              "properties": {
                "amount": {
                  "type": "string",
                  "description": "Decimal string representing the consumer-facing price amount."
                },
                "currency": {
                  "type": "string",
                  "description": "ISO 4217 currency code."
                }
              },
              "additionalProperties": false
            }
          },
          "additionalProperties": false
        },
        "source_offer_id": {
          "type": "string",
          "description": "Upstream source-side offer or inventory identifier."
        },
        "start_at": {
          "type": "string",
          "format": "date-time",
          "description": "RFC 3339 timestamp for when the offer becomes active."
        },
        "expire_at": {
          "type": "string",
          "format": "date-time",
          "description": "RFC 3339 timestamp for when the offer expires."
        },
        "status": {
          "type": "string",
          "enum": [
            "active",
            "paused",
            "pending",
            "rejected",
            "expired"
          ],
          "description": "Lifecycle status of the offer.",
          "default": "pending"
        },
        "audit_status": {
          "type": "string",
          "enum": [
            "waiting",
            "pass",
            "reject"
          ],
          "description": "Compliance audit status.",
          "default": "waiting"
        },
        "priority": {
          "type": "integer",
          "minimum": 0,
          "maximum": 100,
          "description": "Exposure priority. Higher values take precedence.",
          "default": 10
        }
      },
      "additionalProperties": false
    },
    "material": {
      "type": "array",
      "description": "Creative assets associated with the offer.",
      "items": {
        "type": "object",
        "properties": {
          "url": {
            "type": "string",
            "format": "uri",
            "description": "URL to the creative asset."
          },
          "tag": {
            "type": "string",
            "description": "Asset purpose tag such as logo, banner, hero, thumbnail."
          },
          "format": {
            "type": "string",
            "enum": [
              "image",
              "video",
              "html5"
            ],
            "description": "Asset format."
          },
          "dimensions": {
            "type": "string",
            "description": "Dimension specification such as 300x250, 728x90."
          }
        },
        "additionalProperties": false
      }
    },
    "conversion_rule": {
      "type": "object",
      "description": "Rules for valid conversion events, attribution logic, and tracking windows. RECOMMENDED: SHOULD be present to establish clear attribution expectations.",
      "properties": {
        "click_window_hours": {
          "type": "integer",
          "minimum": 0,
          "description": "Click attribution window in hours. Conversions within this window after a click are eligible for attribution.",
          "default": 720
        },
        "view_window_hours": {
          "type": "integer",
          "minimum": 0,
          "description": "View-through attribution window in hours. Default 0 (view-through attribution not supported).",
          "default": 0
        },
        "attribution_model": {
          "type": "string",
          "enum": [
            "last_click",
            "first_click"
          ],
          "description": "Attribution method. last_click: credit goes to the last click before conversion. first_click: credit goes to the first click. linear is reserved for future use.",
          "default": "last_click"
        },
        "accepted_types": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "sale",
              "lead",
              "install",
              "subscription",
              "trial",
              "custom"
            ]
          },
          "description": "Accepted conversion types for this offer. Values reference the conversion_type enumeration."
        },
        "dedup_strategy": {
          "type": "string",
          "enum": [
            "first",
            "all",
            "highest"
          ],
          "description": "Deduplication strategy for multiple conversions from the same user. first: only the first conversion counts. all: every conversion counts. highest: only the highest-value conversion counts.",
          "default": "first"
        },
        "minimum_amount": {
          "type": "string",
          "description": "Minimum conversion amount, decimal string. Conversions below this threshold do not qualify for commission."
        }
      },
      "additionalProperties": false
    },
    "entity": {
      "type": "object",
      "description": "Business entity associated with the offer.",
      "required": [
        "id",
        "name"
      ],
      "properties": {
        "id": {
          "type": "string",
          "description": "Stable entity identifier."
        },
        "name": {
          "type": "string",
          "description": "Display name of the entity."
        },
        "type": {
          "type": "string",
          "enum": ["business", "individual", "institution"],
          "description": "Entity classification. business: registered commercial entity, individual: personal operator, institution: public/non-profit organization."
        },
        "description": {
          "type": "string",
          "description": "Short description of the entity."
        },
        "website": {
          "type": "string",
          "format": "uri",
          "description": "Official website of the entity."
        }
      },
      "additionalProperties": false
    },
    "action": {
      "type": "object",
      "description": "Primary executable action exposed by the offer. Payload structure is constrained by type.",
      "required": [
        "type",
        "payload"
      ],
      "properties": {
        "type": {
          "type": "string",
          "enum": [
            "web_redirect",
            "app_deep_link"
          ],
          "description": "Executable action type."
        },
        "name": {
          "type": "string",
          "description": "Short user-facing action name (CTA text).",
          "maxLength": 80
        },
        "description": {
          "type": "string",
          "description": "Explanation of the action intent or destination.",
          "maxLength": 300
        },
        "payload": {
          "type": "object",
          "required": ["target"],
          "properties": {
            "target": {
              "type": "string",
              "description": "Destination URL or deep link URI."
            }
          }
        }
      },
      "allOf": [
        {
          "if": {
            "properties": { "type": { "const": "web_redirect" } },
            "required": ["type"]
          },
          "then": {
            "properties": {
              "payload": {
                "additionalProperties": false
              }
            }
          }
        },
        {
          "if": {
            "properties": { "type": { "const": "app_deep_link" } },
            "required": ["type"]
          },
          "then": {
            "properties": {
              "payload": {
                "properties": {
                  "platform": {
                    "type": "string",
                    "enum": ["ios", "android"],
                    "description": "Target platform."
                  },
                  "fallback_url": {
                    "type": "string",
                    "format": "uri",
                    "description": "Fallback URL when app is not installed."
                  }
                },
                "additionalProperties": false
              }
            }
          }
        }
      ],
      "additionalProperties": false
    },
    "targeting": {
      "type": "array",
      "description": "Targeting constraints for offer surfacing.",
      "items": {
        "type": "object",
        "properties": {
          "geo": {
            "type": "object",
            "properties": {
              "include": {
                "type": "array",
                "items": {
                  "type": "string"
                },
                "description": "Included geographic regions."
              },
              "exclude": {
                "type": "array",
                "items": {
                  "type": "string"
                },
                "description": "Excluded geographic regions."
              }
            },
            "additionalProperties": false
          },
          "language": {
            "type": "string",
            "description": "Target language, ISO 639-1 code."
          },
          "device_type": {
            "type": "array",
            "items": {
              "type": "string",
              "enum": [
                "mobile",
                "desktop",
                "tablet",
                "smart_tv"
              ]
            },
            "description": "Target device types."
          }
        },
        "additionalProperties": false
      }
    },
    "commission": {
      "type": "object",
      "description": "Affiliate commission and payout information. Partner provides the determined commission amount at offer time.",
      "required": [
        "model",
        "amount",
        "currency"
      ],
      "properties": {
        "model": {
          "type": "string",
          "enum": [
            "cpa",
            "cps",
            "cpl",
            "cpi",
            "hybrid"
          ],
          "description": "Commission model (for display purposes): cpa (cost per action), cps (cost per sale), cpl (cost per lead), cpi (cost per install), hybrid (combined)."
        },
        "amount": {
          "type": "string",
          "description": "Determined commission amount, decimal string."
        },
        "currency": {
          "type": "string",
          "description": "ISO 4217 currency code."
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
